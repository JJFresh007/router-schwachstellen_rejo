@inproceedings{cui2025,
  title = {The {{Application}} of {{BGP Protocol Performance Prediction Models Based}} on {{Deep Neural Networks}} in {{Network Planning}}},
  booktitle = {2025 {{IEEE}} 8th {{International Conference}} on {{Information Systems}} and {{Computer Aided Education}} ({{ICISCAE}})},
  author = {Cui, Zechen and Ma, Yongzheng},
  year = 2025,
  month = sep,
  pages = {1182--1192},
  issn = {2770-663X},
  doi = {10.1109/ICISCAE66104.2025.11307790},
  urldate = {2026-05-23},
  abstract = {Border Gateway Protocol (BGP) serves as the primary routing protocol responsible for exchanging routing information between Internet Autonomous Systems (AS). Accurate BGP performance prediction is crucial for maintaining network stability and optimizing routing decisions. With the rapid evolution of the Internet, modern network architectures have become increasingly complex, exhibiting heterogeneous and highly dynamic characteristics. Networks encompass diverse devices, protocols, and inter-AS connections, making it challenging for traditional BGP performance prediction models to adapt to complex network environments. Traditional models often rely on predefined assumptions, such as static AS relationships, which prove inadequate when confronting constantly changing network topologies, fluctuating traffic patterns, and variable BGP routing decisions in realworld networks. Moreover, the heavy dependence of traditional models on specific data structures and network relationships further limits their generalization capabilities in broader applications.To address these challenges, this paper proposes a novel Deep Neural Network (DNN)-based model for predicting BGP convergence time using historical routing data from sources such as RouteViews and RIPE NCC. Our model employs comprehensive feature engineering, Principal Component Analysis (PCA) for dimensionality reduction, and Dropout regularization to effectively capture complex nonlinear relationships in BGP data. Experimental results demonstrate that the DNN model outperforms traditional methods, achieving an Area Under the Curve (AUC) value of 0.83, with accuracy trends and Receiver Operating Characteristic (ROC) curves validating its superior performance. Future research will incorporate temporal dynamics through Recurrent Neural Networks (RNN) to enhance real-time performance prediction capabilities in dynamic network environments.},
  keywords = {Accuracy,Adaptation models,Autonomous Systems,BGP,Border Gateway Protocol,Convergence,Convergence Time,Data models,Deep Neural Networks,Performance Prediction,Predictive models,Real-time systems,Recurrent neural networks,Routing,Stability analysis}
}

